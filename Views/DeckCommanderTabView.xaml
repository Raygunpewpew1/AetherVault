<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             xmlns:pages="clr-namespace:AetherVault.Pages"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             xmlns:constants="clr-namespace:AetherVault.Constants"
             x:Class="AetherVault.Views.DeckCommanderTabView"
             x:DataType="vm:DeckDetailViewModel">
    <ScrollView Padding="16,8,16,64"
                VerticalOptions="Fill"
                HorizontalOptions="Fill">
        <VerticalStackLayout Spacing="12">
            <!-- No commander placeholder -->
            <VerticalStackLayout IsVisible="{Binding HasNoCommander}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12"
                                 Padding="24,48">
                <Label FontFamily="FASolid"
                       Text="{x:Static fa:Solid.Crown}"
                       FontSize="40"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"
                       Opacity="0.6" />
                <Label Text="No commander set"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center" />
                <Label Text="Search and add a legendary creature (or planeswalker that can be your commander)."
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       MaxLines="4" />
                <Button Command="{Binding RequestAddCardsModalCommand}"
                        Text="{x:Static constants:UserMessages.AddCommander}"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="Black"
                        FontSize="14"
                        CornerRadius="12"
                        Padding="20,10"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Label Text="Commander is hidden by your filter — clear “Find in deck” to show."
                   FontSize="12"
                   TextColor="{StaticResource TextSecondary}"
                   LineBreakMode="WordWrap"
                   IsVisible="{Binding ShowCommanderHiddenByFilterHint}"
                   Margin="0,4,0,0" />

            <!-- Commander: single full-size card -->
            <Grid IsVisible="{Binding ShowCommanderHeroArt}"
                  HorizontalOptions="Start"
                  Margin="0,0,0,12">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DeckListItemTappedCommand}"
                                          CommandParameter="{Binding FirstCommander}" />
                </Grid.GestureRecognizers>
                <Border WidthRequest="220"
                        HeightRequest="308"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="{StaticResource CardBackground}"
                        StrokeThickness="1">
                    <controls:CachedCardImage CardUuid="{Binding FirstCommander.ImageId}"
                                               ImageSize="large"
                                               HorizontalOptions="Fill"
                                               VerticalOptions="Fill" />
                </Border>
                <Button x:Name="CommanderMenuButton"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        Margin="8"
                        WidthRequest="36"
                        HeightRequest="36"
                        CornerRadius="18"
                        BackgroundColor="#CC000000"
                        Padding="0"
                        Clicked="OnCommanderMenuClicked">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="FASolid"
                                         Glyph="{x:Static fa:Solid.EllipsisVertical}"
                                         Size="16"
                                         Color="White" />
                    </Button.ImageSource>
                </Button>
            </Grid>

            <!-- Partner rows: BindableLayout avoids nested CollectionView inside ScrollView (broken vertical scroll on Android). -->
            <VerticalStackLayout IsVisible="{Binding ShowFilteredPartnersSection}"
                                 Spacing="0">
                <Label Text="Partner / other"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextSecondary}"
                       Padding="0,8,0,4" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding FilteredAdditionalCommanderCards}"
                                     Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:DeckCardDisplayItem">
                            <!-- No SwipeView: tap vs swipe fights CachedCardImage / gestures inside ScrollView. -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,6"
                                    Padding="12,10"
                                    MinimumHeightRequest="48">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Stroke" Value="{StaticResource Accent}" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.DeckListItemTappedCommand}"
                                                         CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                      ColumnSpacing="10"
                                      VerticalOptions="Center">
                                    <Border Grid.Column="0"
                                            WidthRequest="36"
                                            HeightRequest="50"
                                            InputTransparent="True"
                                            BackgroundColor="{StaticResource Surface}"
                                            StrokeShape="RoundRectangle 4"
                                            Stroke="Transparent"
                                            VerticalOptions="Center">
                                        <controls:CachedCardImage CardUuid="{Binding ImageId}"
                                                                   InputTransparent="True"
                                                                   HorizontalOptions="Fill"
                                                                   VerticalOptions="Fill" />
                                    </Border>
                                    <Border Grid.Column="1"
                                            BackgroundColor="{StaticResource Accent}"
                                            Padding="6,4"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="Transparent"
                                            VerticalOptions="Center"
                                            MinimumWidthRequest="28">
                                        <Label Text="{Binding DeckQtyLabel}"
                                               TextColor="Black"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding DisplayName}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="14"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding CardTypeText}"
                                               TextColor="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding OwnedShortText}"
                                               FontSize="11"
                                               TextColor="{StaticResource TextSecondary}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsOverCollection}" Value="True">
                                                    <Setter Property="TextColor" Value="#FFB74D" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </VerticalStackLayout>
                                    <Button Grid.Column="3"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.RemoveCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#B00020"
                                            WidthRequest="44"
                                            HeightRequest="44"
                                            Padding="0"
                                            CornerRadius="8"
                                            VerticalOptions="Center">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.TrashCan}"
                                                             Size="16"
                                                             Color="White" />
                                        </Button.ImageSource>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentView>

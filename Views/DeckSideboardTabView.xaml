<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             xmlns:pages="clr-namespace:AetherVault.Pages"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             x:Class="AetherVault.Views.DeckSideboardTabView"
             x:DataType="vm:DeckDetailViewModel">
    <Grid RowDefinitions="Auto,*"
          VerticalOptions="Fill"
          HorizontalOptions="Fill">
        <Label Grid.Row="0"
               Text="{Binding SideboardHeaderText}"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{StaticResource TextSecondary}"
               BackgroundColor="{StaticResource Background}"
               Padding="12,8,12,4" />
        <Grid Grid.Row="1"
              VerticalOptions="Fill"
              HorizontalOptions="Fill">
            <CollectionView x:Name="SideboardCollection"
                            ItemsSource="{Binding FilteredSideboardCards}"
                            SelectionMode="Single"
                            SelectionChanged="OnSideboardItemSelected"
                            VerticalOptions="Fill"
                            HorizontalOptions="Fill"
                            IsVisible="{Binding IsDeckEditorLayoutStandard}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeckCardDisplayItem">
                        <Border Margin="12,5"
                                Padding="12,10"
                                MinimumHeightRequest="60"
                                Background="{Binding StripBackground}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="Transparent"
                                StrokeThickness="0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Stroke" Value="{StaticResource Accent}" />
                                    <Setter Property="StrokeThickness" Value="2" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10"
                                  RowDefinitions="Auto,Auto"
                                  VerticalOptions="Center">
                                <Grid Grid.RowSpan="2"
                                      WidthRequest="48"
                                      HeightRequest="68"
                                      VerticalOptions="Center">
                                    <Border StrokeShape="RoundRectangle 6"
                                            Stroke="{StaticResource CardBackground}"
                                            StrokeThickness="1"
                                            Padding="0">
                                        <Grid>
                                            <controls:CachedCardImage CardUuid="{Binding ImageId}"
                                                                       ImageSize="small"
                                                                       InputTransparent="True"
                                                                       HorizontalOptions="Fill"
                                                                       VerticalOptions="Fill" />
                                            <Button HorizontalOptions="Start"
                                                    VerticalOptions="Start"
                                                    Margin="2"
                                                    WidthRequest="26"
                                                    HeightRequest="26"
                                                    Padding="0"
                                                    CornerRadius="13"
                                                    BackgroundColor="#99000000"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.RequestSideboardDeckGridMenuCommand}"
                                                    CommandParameter="{Binding .}"
                                                    SemanticProperties.Hint="More actions">
                                                <Button.ImageSource>
                                                    <FontImageSource FontFamily="FASolid"
                                                                     Glyph="{x:Static fa:Solid.EllipsisVertical}"
                                                                     Size="12"
                                                                     Color="White" />
                                                </Button.ImageSource>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <VerticalStackLayout Grid.Row="0"
                                                     Grid.Column="1"
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding DisplayName}"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="15"
                                           LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding CardTypeText}"
                                               FontSize="11"
                                               TextColor="{StaticResource TextSecondary}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding OwnedShortText}"
                                               FontSize="11"
                                               TextColor="{StaticResource TextSecondary}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsOverCollection}" Value="True">
                                                    <Setter Property="TextColor" Value="#FFB74D" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Grid Grid.Row="1"
                                      Grid.Column="1"
                                      ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                                      ColumnSpacing="10"
                                      VerticalOptions="Center">
                                    <controls:ManaCostView Grid.Column="0"
                                                             InputTransparent="True"
                                                             ManaText="{Binding ManaCostText}"
                                                             SymbolSize="14"
                                                             VerticalOptions="Center" />
                                    <Border Grid.Column="2"
                                            BackgroundColor="{StaticResource Surface}"
                                            Padding="8,4"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="Transparent"
                                            VerticalOptions="Center"
                                            MinimumWidthRequest="28">
                                        <Label Text="{Binding DeckQtyLabel}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center" />
                                    </Border>
                                    <Button Grid.Column="3"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.DecrementCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Surface}"
                                            TextColor="{StaticResource TextPrimary}"
                                            WidthRequest="40"
                                            HeightRequest="40"
                                            Padding="0"
                                            CornerRadius="8">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.Minus}"
                                                             Size="14"
                                                             Color="{StaticResource TextPrimary}" />
                                        </Button.ImageSource>
                                    </Button>
                                    <Button Grid.Column="4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.IncrementCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Accent}"
                                            TextColor="Black"
                                            WidthRequest="40"
                                            HeightRequest="40"
                                            Padding="0"
                                            CornerRadius="8">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.Plus}"
                                                             Size="14"
                                                             Color="Black" />
                                        </Button.ImageSource>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <BoxView HeightRequest="72"
                             Color="Transparent" />
                </CollectionView.Footer>
            </CollectionView>

            <CollectionView x:Name="SideboardCompactCollection"
                            ItemsSource="{Binding FilteredSideboardCards}"
                            SelectionMode="Single"
                            SelectionChanged="OnSideboardItemSelected"
                            VerticalOptions="Fill"
                            HorizontalOptions="Fill"
                            IsVisible="{Binding IsDeckEditorLayoutCompact}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeckCardDisplayItem">
                        <Border Margin="8,3"
                                Padding="8,6"
                                MinimumHeightRequest="52"
                                Background="{Binding StripBackground}"
                                StrokeShape="RoundRectangle 6"
                                Stroke="Transparent"
                                StrokeThickness="0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Stroke" Value="{StaticResource Accent}" />
                                    <Setter Property="StrokeThickness" Value="2" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8"
                                  RowDefinitions="Auto,Auto"
                                  VerticalOptions="Center">
                                <Grid Grid.RowSpan="2"
                                      WidthRequest="40"
                                      HeightRequest="56"
                                      VerticalOptions="Center">
                                    <Border StrokeShape="RoundRectangle 5"
                                            Stroke="{StaticResource CardBackground}"
                                            StrokeThickness="1"
                                            Padding="0">
                                        <Grid>
                                            <controls:CachedCardImage CardUuid="{Binding ImageId}"
                                                                       ImageSize="small"
                                                                       InputTransparent="True"
                                                                       HorizontalOptions="Fill"
                                                                       VerticalOptions="Fill" />
                                            <Button HorizontalOptions="Start"
                                                    VerticalOptions="Start"
                                                    Margin="1"
                                                    WidthRequest="22"
                                                    HeightRequest="22"
                                                    Padding="0"
                                                    CornerRadius="11"
                                                    BackgroundColor="#99000000"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.RequestSideboardDeckGridMenuCommand}"
                                                    CommandParameter="{Binding .}"
                                                    SemanticProperties.Hint="More actions">
                                                <Button.ImageSource>
                                                    <FontImageSource FontFamily="FASolid"
                                                                     Glyph="{x:Static fa:Solid.EllipsisVertical}"
                                                                     Size="10"
                                                                     Color="White" />
                                                </Button.ImageSource>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <VerticalStackLayout Grid.Row="0"
                                                     Grid.Column="1"
                                                     Spacing="1"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding DisplayName}"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="14"
                                           LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="{Binding CardTypeText}"
                                               FontSize="10"
                                               TextColor="{StaticResource TextSecondary}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding OwnedShortText}"
                                               FontSize="10"
                                               TextColor="{StaticResource TextSecondary}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsOverCollection}" Value="True">
                                                    <Setter Property="TextColor" Value="#FFB74D" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Grid Grid.Row="1"
                                      Grid.Column="1"
                                      ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                                      ColumnSpacing="6"
                                      VerticalOptions="Center">
                                    <controls:ManaCostView Grid.Column="0"
                                                             InputTransparent="True"
                                                             ManaText="{Binding ManaCostText}"
                                                             SymbolSize="12"
                                                             VerticalOptions="Center" />
                                    <Border Grid.Column="2"
                                            BackgroundColor="{StaticResource Surface}"
                                            Padding="6,3"
                                            StrokeShape="RoundRectangle 6"
                                            Stroke="Transparent"
                                            VerticalOptions="Center"
                                            MinimumWidthRequest="24">
                                        <Label Text="{Binding DeckQtyLabel}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center" />
                                    </Border>
                                    <Button Grid.Column="3"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.DecrementCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Surface}"
                                            TextColor="{StaticResource TextPrimary}"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            Padding="0"
                                            CornerRadius="6">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.Minus}"
                                                             Size="12"
                                                             Color="{StaticResource TextPrimary}" />
                                        </Button.ImageSource>
                                    </Button>
                                    <Button Grid.Column="4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.IncrementCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Accent}"
                                            TextColor="Black"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            Padding="0"
                                            CornerRadius="6">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.Plus}"
                                                             Size="12"
                                                             Color="Black" />
                                        </Button.ImageSource>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <BoxView HeightRequest="72"
                             Color="Transparent" />
                </CollectionView.Footer>
            </CollectionView>

            <CollectionView x:Name="SideboardGridCollection"
                            ItemsSource="{Binding FilteredSideboardCards}"
                            SelectionMode="Single"
                            SelectionChanged="OnSideboardItemSelected"
                            VerticalOptions="Fill"
                            HorizontalOptions="Fill"
                            IsVisible="{Binding IsDeckEditorLayoutGrid}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="3"
                                     HorizontalItemSpacing="6"
                                     VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeckCardDisplayItem">
                        <Border Margin="4,2"
                                Padding="4"
                                BackgroundColor="{StaticResource Surface}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="Transparent"
                                StrokeThickness="0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Stroke" Value="{StaticResource Accent}" />
                                    <Setter Property="StrokeThickness" Value="2" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Grid Grid.Row="0"
                                      HeightRequest="152"
                                      HorizontalOptions="Fill">
                                    <controls:CachedCardImage CardUuid="{Binding ImageId}"
                                                               ImageSize="normal"
                                                               InputTransparent="True"
                                                               HorizontalOptions="Fill"
                                                               VerticalOptions="Fill" />
                                    <Button HorizontalOptions="Start"
                                            VerticalOptions="Start"
                                            Margin="4"
                                            WidthRequest="32"
                                            HeightRequest="32"
                                            Padding="0"
                                            CornerRadius="16"
                                            BackgroundColor="#99000000"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.RequestSideboardDeckGridMenuCommand}"
                                            CommandParameter="{Binding .}"
                                            SemanticProperties.Hint="More actions">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.EllipsisVertical}"
                                                             Size="14"
                                                             Color="White" />
                                        </Button.ImageSource>
                                    </Button>
                                    <Border HorizontalOptions="End"
                                            VerticalOptions="End"
                                            Margin="4"
                                            Padding="6,3"
                                            BackgroundColor="#CC000000"
                                            StrokeShape="RoundRectangle 6"
                                            StrokeThickness="0">
                                        <Label Text="{Binding DeckQtyLabel}"
                                               TextColor="White"
                                               FontSize="12"
                                               FontAttributes="Bold" />
                                    </Border>
                                </Grid>
                                <Grid Grid.Row="1"
                                      ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="4">
                                    <Label Grid.Column="0"
                                           Text="{Binding DisplayName}"
                                           FontSize="11"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center" />
                                    <Button Grid.Column="1"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.DecrementCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource CardBackground}"
                                            TextColor="{StaticResource TextPrimary}"
                                            WidthRequest="32"
                                            HeightRequest="32"
                                            Padding="0"
                                            CornerRadius="6">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.Minus}"
                                                             Size="11"
                                                             Color="{StaticResource TextPrimary}" />
                                        </Button.ImageSource>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.IncrementCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Accent}"
                                            TextColor="Black"
                                            WidthRequest="32"
                                            HeightRequest="32"
                                            Padding="0"
                                            CornerRadius="6">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.Plus}"
                                                             Size="11"
                                                             Color="Black" />
                                        </Button.ImageSource>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <BoxView HeightRequest="72"
                             Color="Transparent" />
                </CollectionView.Footer>
            </CollectionView>
        </Grid>
    </Grid>
</ContentView>

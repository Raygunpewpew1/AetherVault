<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             x:Class="AetherVault.Pages.CardQuickDetailPage"
             Title="Card details"
             BackgroundColor="{StaticResource Background}"
             x:DataType="vm:DeckCardDisplayItem">

    <Grid RowDefinitions="Auto,*" Padding="16">

        <ScrollView Grid.Row="1" VerticalOptions="Fill">
            <VerticalStackLayout Spacing="16">

                <!-- Card image -->
                <Border WidthRequest="220"
                        HeightRequest="308"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        HorizontalOptions="Center">
                    <controls:CachedCardImage x:Name="CardImage"
                                             CardUuid="{Binding ImageId}"
                                             HorizontalOptions="Fill"
                                             VerticalOptions="Fill" />
                </Border>

                <!-- Name + mana cost -->
                <Border Style="{StaticResource CardStyle}" Padding="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Text="{Binding DisplayName}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap"
                               VerticalOptions="Center" />
                        <controls:ManaCostView Grid.Column="1"
                                               ManaText="{Binding ManaCostText}"
                                               SymbolSize="14"
                                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Type line -->
                <Label Text="{Binding CardTypeText}"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       LineBreakMode="WordWrap" />

                <!-- Power/toughness or loyalty -->
                <Label x:Name="PTLabel"
                       Text="{Binding PTOrLoyaltyText}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                <!-- In deck -->
                <Border Style="{StaticResource CardStyle}" Padding="12">
                    <Label Text="{Binding InDeckSummary}"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />
                </Border>

                <!-- Rules text -->
                <Border Style="{StaticResource CardStyle}" Padding="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Rules text"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" />
                        <Label Text="{Binding RulesText}"
                               FontSize="13"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- View full details button -->
                <Button x:Name="ViewFullButton"
                        Text="View full details"
                        Clicked="OnViewFullClicked"
                        BackgroundColor="{StaticResource Surface}"
                        TextColor="{StaticResource TextPrimary}"
                        HeightRequest="48"
                        CornerRadius="12"
                        StyleClass="OutlinedButton" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
               xmlns:vm="clr-namespace:AetherVault.ViewModels"
               xmlns:pages="clr-namespace:AetherVault.Pages"
               xmlns:constants="clr-namespace:AetherVault.Constants"
               xmlns:deckbrowse="clr-namespace:AetherVault.Services.DeckBuilder;assembly=AetherVault"
               x:Class="AetherVault.Pages.DeckAddCardsBrowsePopup"
               x:Name="BrowsePopupRoot"
               x:DataType="vm:DeckAddCardsViewModel"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <Border BackgroundColor="{StaticResource Surface}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 20,20,0,0"
            VerticalOptions="End"
            HorizontalOptions="Fill"
            MaximumHeightRequest="520"
            Margin="0">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,-2" Radius="14" Opacity="0.28" />
        </Border.Shadow>

        <Grid RowDefinitions="Auto,*,Auto"
              Padding="0,0,0,8">
            <VerticalStackLayout Grid.Row="0"
                                 Spacing="4"
                                 Padding="20,16,20,8">
                <Label Text="{x:Static constants:UserMessages.DeckAddBrowseMoreTitle}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Start" />
                <Label Text="{x:Static constants:UserMessages.DeckAddBrowseSheetSubtitle}"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <ScrollView Grid.Row="1"
                        Padding="12,0,12,0"
                        VerticalOptions="Fill">
                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="8"
                                         IsVisible="{Binding HasSynergyPresetChips}">
                        <Label Text="{x:Static constants:UserMessages.DeckAddSynergyChipsTitle}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" />
                        <CollectionView ItemsSource="{Binding AddCardSynergyPresetChips}"
                                        SelectionMode="None"
                                        HeightRequest="44"
                                        HorizontalScrollBarVisibility="Never">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:DeckSynergyChipItem">
                                    <Button Text="{Binding DisplayText}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckAddCardsBrowsePopup}}, Path=BindingContext.ApplyAddCardSynergyPresetCommand}"
                                            CommandParameter="{Binding .}"
                                            FontSize="11"
                                            Padding="12,8"
                                            CornerRadius="16"
                                            BackgroundColor="{StaticResource CardBackground}"
                                            TextColor="{StaticResource TextPrimary}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="{x:Static constants:UserMessages.DeckAddQuickListsTitle}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" />
                        <CollectionView ItemsSource="{Binding QuickBrowseListChips}"
                                        SelectionMode="None"
                                        HeightRequest="44"
                                        HorizontalScrollBarVisibility="Never">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="deckbrowse:DeckBrowseListChipItem">
                                    <Button Text="{Binding DisplayText}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckAddCardsBrowsePopup}}, Path=BindingContext.ApplyQuickBrowseListCommand}"
                                            CommandParameter="{Binding .}"
                                            FontSize="11"
                                            Padding="12,8"
                                            CornerRadius="16"
                                            BackgroundColor="{StaticResource CardBackground}"
                                            TextColor="{StaticResource TextPrimary}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8"
                                         IsVisible="{Binding ShowDeckSuggestionUi}">
                        <Label Text="{x:Static constants:UserMessages.DeckAddStrategyTitle}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" />
                        <Picker Title="Strategy"
                                TitleColor="{StaticResource TextSecondary}"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="{StaticResource CardBackground}"
                                ItemsSource="{Binding CommanderArchetypePickerItems}"
                                SelectedIndex="{Binding CommanderArchetypePickerIndex, Mode=TwoWay}" />
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Text="{x:Static constants:UserMessages.DeckAddLoadSuggestions}"
                                    Command="{Binding LoadDeckSuggestionsCommand}"
                                    BackgroundColor="{StaticResource Accent}"
                                    TextColor="Black"
                                    CornerRadius="8"
                                    Padding="12,8" />
                            <ActivityIndicator Grid.Column="1"
                                               IsRunning="{Binding IsDeckSuggestionBusy}"
                                               IsVisible="{Binding IsDeckSuggestionBusy}"
                                               HeightRequest="28"
                                               WidthRequest="28"
                                               VerticalOptions="Center"
                                               Color="{StaticResource Primary}" />
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <Button Grid.Row="2"
                    Text="{x:Static constants:UserMessages.DeckAddBrowseClose}"
                    Clicked="OnCloseClicked"
                    Margin="20,12,20,4"
                    Padding="16,12"
                    CornerRadius="12"
                    BackgroundColor="{StaticResource CardBackground}"
                    TextColor="{StaticResource TextPrimary}" />
        </Grid>
    </Border>
</toolkit:Popup>

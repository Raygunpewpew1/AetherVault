<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
               xmlns:controls="clr-namespace:AetherVault.Controls"
               xmlns:viewmodels="clr-namespace:AetherVault.ViewModels"
               xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
               x:Class="AetherVault.Pages.SearchFiltersSheet"
               x:DataType="viewmodels:SearchFiltersViewModel"
               x:Name="SheetRoot"
               CanBeDismissedByTappingOutsideOfPopup="True"
               HorizontalOptions="Fill"
               VerticalOptions="End"
               BackgroundColor="Transparent">

    <toolkit:Popup.Resources>
        <ResourceDictionary>
            <OnIdiom x:Key="HeaderFontSize" x:TypeArguments="x:Double" Phone="18" Tablet="20" Desktop="20" />
            <OnIdiom x:Key="BodyFontSize" x:TypeArguments="x:Double" Phone="14" Tablet="16" Desktop="16" />
            <OnIdiom x:Key="SmallFontSize" x:TypeArguments="x:Double" Phone="12" Tablet="14" Desktop="14" />
        </ResourceDictionary>
    </toolkit:Popup.Resources>

    <Border BackgroundColor="{StaticResource CardBackground}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 20,20,0,0"
            Margin="0"
            VerticalOptions="End"
            HorizontalOptions="Fill">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,-2" Radius="16" Opacity="0.35" />
        </Border.Shadow>

        <Grid RowDefinitions="Auto,Auto,*,Auto"
              MinimumHeightRequest="420"
              MaximumHeightRequest="780">

            <!-- Header -->
            <VerticalStackLayout Grid.Row="0"
                                 Spacing="8"
                                 Padding="20,16,20,12"
                                 BackgroundColor="Transparent">
                <BoxView HeightRequest="4"
                         WidthRequest="40"
                         HorizontalOptions="Center"
                         Color="{StaticResource TextSecondary}"
                         Opacity="0.6"
                         CornerRadius="2" />
                <Label Text="Search filters"
                       FontSize="{StaticResource HeaderFontSize}"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center" />
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10"
                      IsVisible="{Binding HasActiveFilters}">
                    <Label Text="{Binding FiltersSummaryText}"
                           FontSize="{StaticResource SmallFontSize}"
                           TextColor="{StaticResource TextSecondary}"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="Clear all"
                            Command="{Binding ClearAllCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Primary}"
                            FontSize="{StaticResource SmallFontSize}"
                            Padding="10,6"
                            VerticalOptions="Center" />
                </Grid>
            </VerticalStackLayout>

            <!-- Category segments + divider -->
            <VerticalStackLayout Grid.Row="1"
                                 Spacing="0"
                                 Padding="0,0,0,0">
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            Padding="16,0,16,12">
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="General"
                                Style="{StaticResource FilterCategoryButtonStyle}"
                                Command="{Binding SelectCategoryCommand}"
                                CommandParameter="0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsFilterGeneralVisible}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="Mana &amp; stats"
                                Style="{StaticResource FilterCategoryButtonStyle}"
                                Command="{Binding SelectCategoryCommand}"
                                CommandParameter="1">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsFilterManaVisible}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="Print"
                                Style="{StaticResource FilterCategoryButtonStyle}"
                                Command="{Binding SelectCategoryCommand}"
                                CommandParameter="2">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsFilterPrintVisible}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="Options"
                                Style="{StaticResource FilterCategoryButtonStyle}"
                                Command="{Binding SelectCategoryCommand}"
                                CommandParameter="3">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsFilterOptionsVisible}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </HorizontalStackLayout>
                </ScrollView>
                <BoxView HeightRequest="1"
                         Color="{StaticResource FilterHairline}"
                         Margin="16,0" />
            </VerticalStackLayout>

            <!-- Content -->
            <ScrollView Grid.Row="2"
                        Padding="20,8,20,16">
                <VerticalStackLayout Spacing="0">

                    <!-- General -->
                    <VerticalStackLayout IsVisible="{Binding IsFilterGeneralVisible}"
                                         Spacing="16">
                        <Label Text="Colors"
                               Style="{StaticResource FilterSectionTitleLabelStyle}" />
                        <controls:ManaColorFilterRow ItemsSource="{Binding ColorFilters}"
                                                     ToggleColorCommand="{Binding ToggleColorCommand}" />

                        <BoxView HeightRequest="1"
                                 Color="{StaticResource FilterHairline}"
                                 Margin="0,8,0,8" />

                        <Label Text="Card text &amp; type"
                               Style="{StaticResource FilterSectionTitleLabelStyle}" />
                        <material:TextField Text="{Binding Keywords, Mode=TwoWay}"
                                            Title="Rules text"
                                            TitleColor="{StaticResource TextSecondary}"
                                            AccentColor="{StaticResource Primary}"
                                            MinimumHeightRequest="56" />
                        <material:PickerField SelectedIndex="{Binding SelectedTypeIndex, Mode=TwoWay}"
                                              ItemsSource="{Binding TypeOptions}"
                                              Title="Card type"
                                              TextColor="{StaticResource TextPrimary}"
                                              TitleColor="{StaticResource TextSecondary}"
                                              AccentColor="{StaticResource Primary}"
                                              MinimumHeightRequest="56"
                                              Margin="0,8,0,0" />
                        <material:TextField Text="{Binding Subtype, Mode=TwoWay}"
                                            Title="Subtype"
                                            TitleColor="{StaticResource TextSecondary}"
                                            AccentColor="{StaticResource Primary}"
                                            MinimumHeightRequest="56"
                                            Margin="0,8,0,0" />
                        <material:TextField Text="{Binding Supertype, Mode=TwoWay}"
                                            Title="Supertype"
                                            TitleColor="{StaticResource TextSecondary}"
                                            AccentColor="{StaticResource Primary}"
                                            MinimumHeightRequest="56"
                                            Margin="0,8,0,0" />

                        <BoxView HeightRequest="1"
                                 Color="{StaticResource FilterHairline}"
                                 Margin="0,8,0,8" />

                        <Label Text="Rarity"
                               Style="{StaticResource FilterSectionTitleLabelStyle}" />
                        <FlexLayout Wrap="Wrap"
                                    JustifyContent="Start"
                                    AlignItems="Start">
                            <!-- Common -->
                            <Border StrokeShape="RoundRectangle 20"
                                    StrokeThickness="1"
                                    Padding="14,10"
                                    Margin="0,0,8,8">
                                <Border.Stroke>
                                    <SolidColorBrush Color="{StaticResource RarityCommon}" />
                                </Border.Stroke>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleRarityCommand}"
                                                          CommandParameter="C" />
                                </Border.GestureRecognizers>
                                <Label Text="Common"
                                       FontSize="13"
                                       TextColor="{StaticResource RarityCommon}" />
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding ChkCommon}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource FilterChipSelectedFill}" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                    </DataTrigger>
                                </Border.Triggers>
                            </Border>
                            <!-- Uncommon -->
                            <Border StrokeShape="RoundRectangle 20"
                                    StrokeThickness="1"
                                    Padding="14,10"
                                    Margin="0,0,8,8">
                                <Border.Stroke>
                                    <SolidColorBrush Color="{StaticResource RarityUncommon}" />
                                </Border.Stroke>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleRarityCommand}"
                                                          CommandParameter="U" />
                                </Border.GestureRecognizers>
                                <Label Text="Uncommon"
                                       FontSize="13"
                                       TextColor="{StaticResource RarityUncommon}" />
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding ChkUncommon}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource FilterChipSelectedFill}" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                    </DataTrigger>
                                </Border.Triggers>
                            </Border>
                            <!-- Rare -->
                            <Border StrokeShape="RoundRectangle 20"
                                    StrokeThickness="1"
                                    Padding="14,10"
                                    Margin="0,0,8,8">
                                <Border.Stroke>
                                    <SolidColorBrush Color="{StaticResource RarityRare}" />
                                </Border.Stroke>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleRarityCommand}"
                                                          CommandParameter="R" />
                                </Border.GestureRecognizers>
                                <Label Text="Rare"
                                       FontSize="13"
                                       TextColor="{StaticResource RarityRare}" />
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding ChkRare}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource FilterChipSelectedFill}" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                    </DataTrigger>
                                </Border.Triggers>
                            </Border>
                            <!-- Mythic -->
                            <Border StrokeShape="RoundRectangle 20"
                                    StrokeThickness="1"
                                    Padding="14,10"
                                    Margin="0,0,8,8">
                                <Border.Stroke>
                                    <SolidColorBrush Color="{StaticResource RarityMythic}" />
                                </Border.Stroke>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleRarityCommand}"
                                                          CommandParameter="M" />
                                </Border.GestureRecognizers>
                                <Label Text="Mythic"
                                       FontSize="13"
                                       TextColor="{StaticResource RarityMythic}" />
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding ChkMythic}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource FilterChipSelectedFill}" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                    </DataTrigger>
                                </Border.Triggers>
                            </Border>
                        </FlexLayout>
                    </VerticalStackLayout>

                    <!-- Mana & stats -->
                    <VerticalStackLayout IsVisible="{Binding IsFilterManaVisible}"
                                         Spacing="16">
                        <Label Text="Mana value (CMC)"
                               Style="{StaticResource FilterSectionTitleLabelStyle}" />
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <Button Text="−"
                                    Style="{StaticResource FilterCmcStepperButtonStyle}"
                                    Command="{Binding AdjustCmcCommand}"
                                    CommandParameter="min-" />
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="{Binding CmcMinLabel}"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center" />
                                <Label Text="Minimum"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="+"
                                    Style="{StaticResource FilterCmcStepperButtonStyle}"
                                    Command="{Binding AdjustCmcCommand}"
                                    CommandParameter="min+" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12"
                              Margin="0,8,0,0">
                            <Button Text="−"
                                    Style="{StaticResource FilterCmcStepperButtonStyle}"
                                    Command="{Binding AdjustCmcCommand}"
                                    CommandParameter="max-" />
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="{Binding CmcMaxLabel}"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center" />
                                <Label Text="Maximum"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="+"
                                    Style="{StaticResource FilterCmcStepperButtonStyle}"
                                    Command="{Binding AdjustCmcCommand}"
                                    CommandParameter="max+" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="{StaticResource FilterHairline}"
                                 Margin="0,16,0,8" />

                        <Label Text="Power &amp; toughness"
                               Style="{StaticResource FilterSectionTitleLabelStyle}" />
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <material:TextField Text="{Binding Power, Mode=TwoWay}"
                                                Title="Power"
                                                Keyboard="Numeric"
                                                TitleColor="{StaticResource TextSecondary}"
                                                AccentColor="{StaticResource Primary}"
                                                MinimumHeightRequest="56" />
                            <material:TextField Grid.Column="1"
                                                Text="{Binding Toughness, Mode=TwoWay}"
                                                Title="Toughness"
                                                Keyboard="Numeric"
                                                TitleColor="{StaticResource TextSecondary}"
                                                AccentColor="{StaticResource Primary}"
                                                MinimumHeightRequest="56" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Print -->
                    <VerticalStackLayout IsVisible="{Binding IsFilterPrintVisible}"
                                         Spacing="16">
                        <material:PickerField SelectedIndex="{Binding SelectedFormatIndex, Mode=TwoWay}"
                                              ItemsSource="{Binding FormatOptions}"
                                              Title="Format legality"
                                              TextColor="{StaticResource TextPrimary}"
                                              TitleColor="{StaticResource TextSecondary}"
                                              AccentColor="{StaticResource Primary}"
                                              MinimumHeightRequest="56" />

                        <Label Text="Set"
                               Style="{StaticResource FilterSectionTitleLabelStyle}"
                               Margin="0,8,0,0" />
                        <Border BackgroundColor="{StaticResource Surface}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSetFieldTapped" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">
                                <Label Text="{Binding SelectedSetDisplayName}"
                                       FontSize="{StaticResource BodyFontSize}"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation" />
                                <Label Grid.Column="1"
                                       FontFamily="FASolid"
                                       Text="{x:Static fa:Solid.ChevronDown}"
                                       FontSize="14"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <material:TextField Text="{Binding Artist, Mode=TwoWay}"
                                            Title="Artist"
                                            TitleColor="{StaticResource TextSecondary}"
                                            AccentColor="{StaticResource Primary}"
                                            MinimumHeightRequest="56"
                                            Margin="0,8,0,0" />
                    </VerticalStackLayout>

                    <!-- Options -->
                    <VerticalStackLayout IsVisible="{Binding IsFilterOptionsVisible}"
                                         Spacing="4">
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="0,12"
                              ColumnSpacing="12">
                            <Label Text="Primary side only"
                                   VerticalOptions="Center"
                                   FontSize="{StaticResource BodyFontSize}"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding ChkPrimarySide, Mode=TwoWay}"
                                    OnColor="{StaticResource Primary}"
                                    VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FilterHairline}" />
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="0,12"
                              ColumnSpacing="12">
                            <Label Text="Exclude variations"
                                   VerticalOptions="Center"
                                   FontSize="{StaticResource BodyFontSize}"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding ChkNoVariations, Mode=TwoWay}"
                                    OnColor="{StaticResource Primary}"
                                    VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FilterHairline}" />
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="0,12"
                              ColumnSpacing="12">
                            <Label Text="Include tokens"
                                   VerticalOptions="Center"
                                   FontSize="{StaticResource BodyFontSize}"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding ChkIncludeTokens, Mode=TwoWay}"
                                    OnColor="{StaticResource Primary}"
                                    VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FilterHairline}" />
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="0,12"
                              ColumnSpacing="12">
                            <Label Text="Can be commander only"
                                   VerticalOptions="Center"
                                   FontSize="{StaticResource BodyFontSize}"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding ChkCommanderOnly, Mode=TwoWay}"
                                    OnColor="{StaticResource Primary}"
                                    VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Footer -->
            <VerticalStackLayout Grid.Row="3"
                                 Spacing="0"
                                 BackgroundColor="{StaticResource CardBackground}">
                <BoxView HeightRequest="1"
                         Color="{StaticResource FilterHairline}" />
                <Grid Padding="20,14,20,28"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="10">
                    <Button Text="Reset"
                            Command="{Binding ResetCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextSecondary}"
                            BorderColor="{StaticResource TextSecondary}"
                            BorderWidth="1"
                            CornerRadius="10"
                            HorizontalOptions="Fill"
                            FontSize="13"
                            MinimumHeightRequest="48"
                            Padding="8,12" />
                    <Button Grid.Column="1"
                            Text="Cancel"
                            Command="{Binding CancelCommand}"
                            BackgroundColor="{StaticResource Surface}"
                            TextColor="{StaticResource TextPrimary}"
                            CornerRadius="10"
                            HorizontalOptions="Fill"
                            FontSize="13"
                            MinimumHeightRequest="48"
                            Padding="8,12" />
                    <Button Grid.Column="2"
                            Text="Apply"
                            Command="{Binding ApplyCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="10"
                            HorizontalOptions="Fill"
                            FontSize="13"
                            MinimumHeightRequest="48"
                            Padding="8,12" />
                </Grid>
            </VerticalStackLayout>

        </Grid>

    </Border>

</toolkit:Popup>

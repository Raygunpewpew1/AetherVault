<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             x:Class="AetherVault.Pages.CollectionPage"
             x:DataType="vm:CollectionViewModel"
             Title="Collection"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- Single compact toolbar: filter, stats, actions -->
        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Padding="8,6"
                Margin="6,4,6,4">
            <VerticalStackLayout Spacing="4">

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="6">
                    <material:TextField Title="Filter"
                                        Text="{Binding FilterText, Mode=TwoWay}"
                                        TitleColor="{StaticResource TextSecondary}"
                                        AccentColor="{StaticResource Primary}"
                                        AllowClear="True" />
                    <material:PickerField Grid.Column="1"
                                          Title="Sort"
                                          ItemsSource="{Binding SortModeOptions}"
                                          SelectedIndex="{Binding SortModeIndex, Mode=TwoWay}"
                                          TextColor="{StaticResource TextPrimary}"
                                          TitleColor="{StaticResource TextSecondary}"
                                          AccentColor="{StaticResource Primary}"
                                          WidthRequest="100" />
                </Grid>

                <!-- Stats, status, busy, view mode — one line -->
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="6">
                    <HorizontalStackLayout Spacing="6"
                                           VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="2"
                                               VerticalOptions="Center">
                            <Label Text="{Binding TotalCards}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Label Text="cards"
                                   FontSize="10"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label Text="·"
                               FontSize="10"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" />
                        <HorizontalStackLayout Spacing="2"
                                               VerticalOptions="Center">
                            <Label Text="{Binding UniqueCards}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Label Text="unique"
                                   FontSize="10"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>

                    <Label Grid.Column="1"
                           x:Name="CollectionStatus"
                           Text="{Binding StatusDisplayText}"
                           FontSize="10"
                           LineBreakMode="TailTruncation"
                           MaxLines="1"
                           VerticalOptions="Center"
                           VerticalTextAlignment="Center"
                           TextColor="{Binding StatusTextColor}" />

                    <HorizontalStackLayout Grid.Column="2"
                                           Spacing="6"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center">
                        <HorizontalStackLayout IsVisible="{Binding IsImportingPrices}"
                                               Spacing="4"
                                               VerticalOptions="Center">
                            <ActivityIndicator IsRunning="{Binding IsImportingPrices}"
                                               HeightRequest="12"
                                               WidthRequest="12"
                                               Color="{StaticResource TextSecondary}" />
                            <Label Text="Prices…"
                                   FontSize="9"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <ActivityIndicator x:Name="CollectionLoading"
                                           IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           HeightRequest="16"
                                           WidthRequest="16"
                                           Color="{StaticResource Primary}" />
                        <Button Text="{Binding ViewModeButtonText}"
                                Command="{Binding ToggleViewModeCommand}"
                                BackgroundColor="{StaticResource CardBackground}"
                                HeightRequest="30"
                                Padding="8,0"
                                FontSize="11"
                                StyleClass="ElevatedButton"
                                ToolTipProperties.Text="{Binding ViewModeToolTip}" />
                    </HorizontalStackLayout>
                </Grid>

                <!-- Icon actions: smaller targets, single row -->
                <Grid ColumnDefinitions="*,*,*,*"
                      Margin="0,2,0,0">
                    <VerticalStackLayout Grid.Column="0"
                                         HorizontalOptions="Center"
                                         Spacing="1"
                                         Padding="2,0"
                                         ToolTipProperties.Text="Import collection">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ImportCollectionCommand}" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label FontFamily="FASolid"
                               Text="{x:Static fa:Solid.FileImport}"
                               FontSize="16"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Primary}" />
                        <Label Text="Import"
                               FontSize="9"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1"
                                         HorizontalOptions="Center"
                                         Spacing="1"
                                         Padding="2,0"
                                         ToolTipProperties.Text="Export collection">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ExportCollectionCommand}" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label FontFamily="FASolid"
                               Text="{x:Static fa:Solid.FileExport}"
                               FontSize="16"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Primary}" />
                        <Label Text="Export"
                               FontSize="9"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2"
                                         HorizontalOptions="Center"
                                         Spacing="1"
                                         Padding="2,0"
                                         ToolTipProperties.Text="Refresh">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding RefreshCommand}" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label FontFamily="FASolid"
                               Text="{x:Static fa:Solid.ArrowsRotate}"
                               FontSize="16"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Primary}" />
                        <Label Text="Refresh"
                               FontSize="9"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="3"
                                         HorizontalOptions="Center"
                                         Spacing="1"
                                         Padding="2,0"
                                         ToolTipProperties.Text="Clear collection">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClearCollectionClicked" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label FontFamily="FASolid"
                               Text="{x:Static fa:Solid.TrashCan}"
                               FontSize="16"
                               HorizontalOptions="Center"
                               TextColor="#CF6679" />
                        <Label Text="Clear"
                               FontSize="9"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Grid>

            </VerticalStackLayout>
        </Border>

        <Grid x:Name="CollectionContentArea"
              Grid.Row="1"
              Margin="0,0,0,2"
              BackgroundColor="{StaticResource Background}">
            <Grid x:Name="CollectionEmptyState"
                  IsVisible="{Binding IsCollectionEmpty}"
                  BackgroundColor="{StaticResource Background}"
                  VerticalOptions="Fill"
                  HorizontalOptions="Fill"
                  MinimumHeightRequest="200">
                <controls:EmptyStateView IconGlyph="{x:Static fa:Solid.BoxArchive}"
                                         Message="Your collection is empty"
                                         SecondaryMessage="Search for cards and long-press to add them" />
            </Grid>
            <controls:CardGrid x:Name="CollectionGrid"
                               IsVisible="{Binding IsCollectionEmpty, Converter={StaticResource InvertedBool}}"
                               Scrolled="OnCollectionScrolled"
                               UseCompactGrid="True" />
        </Grid>

    </Grid>

</ContentPage>
